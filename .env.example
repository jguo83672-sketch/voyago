# Flask配置
SECRET_KEY=your-secret-key-here
DATABASE_URL=sqlite:///voyago.db

# DeepSeek API配置
# 获取API Key: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# 百度智能云 OCR 配置
# 获取方式：https://cloud.baidu.com/product/ocr
# 在控制台创建应用后获取 API Key 和 Secret Key
BAIDU_OCR_API_KEY=your-baidu-ocr-api-key-here
BAIDU_OCR_SECRET_KEY=your-baidu-ocr-secret-key-here

# Google Custom Search API配置（可选）
# 获取API Key: https://console.cloud.google.com/
# 创建自定义搜索引擎: https://cse.google.com/cse/
SEARCH_API_KEY=your-google-search-api-key-here
SEARCH_ENGINE_ID=your-custom-search-engine-id-here
